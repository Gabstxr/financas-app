# Normaliza line endings para LF em todos os arquivos de texto
* text=auto eol=lf

# Dart / Flutter
*.dart text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.sh   text eol=lf
*.gradle text eol=lf
*.xml  text eol=lf
*.html text eol=lf

# Binários — não alterar
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.ttf  binary
*.otf  binary
*.woff binary
*.woff2 binary
*.jar  binary
*.zip  binary
*.apk  binary
*.aab  binary
*.ipa  binary
